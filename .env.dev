# build mode
NODE_ENV=development

# development server port
SERVE_PORT=8501

# content files
CONTENT_DIR=./src/content/

# templates
TEMPLATE_DIR=./src/template/
TEMPLATE_DEFAULT=default.html
TEMPLATE_LIST=list.html
TEMPLATE_TAG=tag.html

# build directory
BUILD_DIR=./build/
BUILD_ROOT=/

# site settings
SITE_LANGUAGE="en-US"
SITE_TITLE="Vywamus"
SITE_DESCRIPTION="Journey into the Alchemy of Consciousness with us at the Vywamus Foundation."
